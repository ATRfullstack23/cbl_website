{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix ./cbl_project",
  "buildCommand": "npm run build --prefix ./cbl_project",
  "outputDirectory": "cbl_project/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
