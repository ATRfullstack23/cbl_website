# Copy to .env and fill in secrets (never commit .env if it has real passwords).
VITE_BASE_PATH=/

# Server + MongoDB (used by server/server.js locally; on Render set in dashboard)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/cbl?retryWrites=true&w=majority
PORT=5000
# CORS_ORIGIN=https://your-site.vercel.app

# Frontend build: full URL of deployed API (no trailing slash). Empty in local dev (Vite proxy).
VITE_API_URL=https://your-api.onrender.com
